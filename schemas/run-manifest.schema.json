{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jhun-kim.github.io/orca-gjc-harness/schemas/run-manifest.schema.json",
  "title": "Orca GJC Harness Run Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "createdAt",
    "coordinatorHandle",
    "parentInvariantBefore",
    "parentInvariantAfter",
    "trust",
    "runtimePolicy",
    "source",
    "mode",
    "tasks",
    "dispatches",
    "worktrees",
    "terminals",
    "promptDeliveries",
    "handoffs",
    "validations",
    "evidence",
    "cleanupReceipts",
    "approvalPolicy",
    "decisionReceipts",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.1" },
    "runId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "coordinatorHandle": { "type": "string", "minLength": 1 },
    "parentInvariantBefore": { "$ref": "#/$defs/parentInvariant" },
    "parentInvariantAfter": { "anyOf": [{ "$ref": "#/$defs/parentInvariant" }, { "type": "null" }] },
    "trust": { "$ref": "#/$defs/trustDecision" },
    "runtimePolicy": { "$ref": "#/$defs/runtimePolicy" },
    "source": { "$ref": "#/$defs/sourceFact" },
    "mode": {
      "type": "object",
      "required": ["selected", "reason", "conditionalIntegration"],
      "additionalProperties": false,
      "properties": {
        "selected": { "enum": ["single", "race", "parallel-build", "pipeline"] },
        "reason": { "type": "string", "minLength": 1 },
        "conditionalIntegration": { "type": "boolean" }
      }
    },
    "tasks": { "type": "array", "items": { "$ref": "#/$defs/task" } },
    "dispatches": { "type": "array", "items": { "$ref": "#/$defs/dispatch" } },
    "worktrees": { "type": "array", "items": { "$ref": "#/$defs/worktree" } },
    "terminals": { "type": "array", "items": { "$ref": "#/$defs/terminal" } },
    "promptDeliveries": { "type": "array", "items": { "$ref": "#/$defs/promptDelivery" } },
    "handoffs": { "type": "array", "items": { "$ref": "#/$defs/handoff" } },
    "validations": { "type": "array", "items": { "$ref": "#/$defs/validation" } },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "cleanupReceipts": { "type": "array", "items": { "$ref": "#/$defs/cleanupReceipt" } },
    "final": { "$ref": "#/$defs/finalReport" },
    "approvalPolicy": { "$ref": "#/$defs/approvalPolicy" },
    "decisionReceipts": { "type": "array", "items": { "$ref": "#/$defs/decisionReceipt" } },
    "status": { "enum": ["planning", "running", "blocked", "failed", "validated", "cleanup-blocked", "complete"] }
  },
  "$defs": {
    "fullOid": { "type": "string", "pattern": "^[0-9a-f]{40,128}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1 },
    "parentInvariant": {
      "type": "object",
      "required": ["path", "branch", "head", "status"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "branch": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }],
          "description": "Null means the worktree is detached."
        },
        "head": { "$ref": "#/$defs/fullOid" },
        "status": { "type": "array", "items": { "type": "string" } }
      }
    },
    "trustDecision": {
      "type": "object",
      "required": ["classification", "rationale", "evidence"],
      "additionalProperties": false,
      "properties": {
        "classification": { "enum": ["trusted", "untrusted", "unknown"] },
        "rationale": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/path" } }
      }
    },
    "runtimePolicy": {
      "type": "object",
      "required": [
        "setupMode",
        "gjcBinary",
        "requestedModel",
        "resolvedModel",
        "requestedThinking",
        "resolvedThinking",
        "tools",
        "goalEnabled",
        "environmentReceipt",
        "configurationIsolationReceipt",
        "sessionIsolationReceipt",
        "authentication",
        "fallbacks"
      ],
      "additionalProperties": false,
      "properties": {
        "setupMode": { "enum": ["skip", "inherit"] },
        "gjcBinary": {
          "type": "object",
          "required": ["path", "sha256", "versionArtifact", "modelCatalogArtifact", "provenance"],
          "additionalProperties": false,
          "properties": {
            "path": { "$ref": "#/$defs/path" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "versionArtifact": { "$ref": "#/$defs/path" },
            "modelCatalogArtifact": { "$ref": "#/$defs/path" },
            "provenance": { "type": "string", "minLength": 1 }
          }
        },
        "requestedModel": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]+$" },
        "resolvedModel": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]+$" },
        "requestedThinking": { "enum": ["ultra", "high", "medium", "low"] },
        "resolvedThinking": { "enum": ["ultra", "high", "medium", "low"] },
        "tools": { "type": "array", "minItems": 1, "items": { "enum": ["read", "search", "find", "edit", "write", "bash"] }, "uniqueItems": true },
        "goalEnabled": {
          "const": false,
          "description": "The goal tool can remain active despite --tools and must be disabled in the isolated config."
        },
        "environmentReceipt": { "$ref": "#/$defs/path" },
        "configurationIsolationReceipt": { "$ref": "#/$defs/path" },
        "sessionIsolationReceipt": { "$ref": "#/$defs/path" },
        "authentication": { "$ref": "#/$defs/authentication" },
        "fallbacks": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]+$" }, "uniqueItems": true }
      }
    },
    "sourceFact": {
      "type": "object",
      "required": ["contractPath", "contractSha256", "sourceHead"],
      "additionalProperties": false,
      "properties": {
        "contractPath": { "$ref": "#/$defs/path" },
        "contractSha256": { "$ref": "#/$defs/sha256" },
        "sourceHead": { "$ref": "#/$defs/fullOid" }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "taskId",
        "dispatchId",
        "phase",
        "dependsOn",
        "required",
        "worktreeId",
        "recordedBase",
        "ownedPaths",
        "model",
        "thinking",
        "promptPath",
        "promptSha256",
        "acceptance",
        "validationCommands",
        "handoffOutputs",
        "status",
        "workerDone"
      ],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "dispatchId": { "type": "string", "minLength": 1 },
        "phase": { "type": "string", "minLength": 1 },
        "dependsOn": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "required": { "type": "boolean" },
        "worktreeId": { "type": "string", "minLength": 1 },
        "recordedBase": { "$ref": "#/$defs/fullOid" },
        "ownedPaths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/path" }, "uniqueItems": true },
        "model": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]+$" },
        "thinking": { "enum": ["ultra", "high", "medium", "low"] },
        "promptPath": { "$ref": "#/$defs/path" },
        "promptSha256": { "$ref": "#/$defs/sha256" },
        "acceptance": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "validationCommands": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "handoffOutputs": { "type": "array", "items": { "$ref": "#/$defs/path" } },
        "status": {
          "enum": ["pending", "ready", "dispatched", "completed", "failed", "blocked", "cancelled", "cleanup-blocked"],
          "description": "Orca task lifecycle state, distinct from worker_done status."
        },
        "workerDone": { "$ref": "#/$defs/workerDoneResult" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
          "then": {
            "properties": {
              "workerDone": {
                "type": "object",
                "properties": { "status": { "const": "success" } },
                "required": ["status"]
              }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] },
          "then": {
            "properties": {
              "workerDone": {
                "type": "object",
                "properties": { "status": { "const": "failure" } },
                "required": ["status"]
              }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "blocked" } }, "required": ["status"] },
          "then": {
            "properties": {
              "workerDone": {
                "type": "object",
                "properties": { "status": { "const": "blocked" } },
                "required": ["status"]
              }
            }
          }
        }
      ]
    },
    "workerDoneResult": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["status", "receipt"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "enum": ["success", "failure", "blocked"],
              "description": "Exact completion-receipt status vocabulary."
            },
            "receipt": { "$ref": "#/$defs/evidence" }
          }
        }
      ]
    },
    "dispatch": {
      "type": "object",
      "required": ["taskId", "dispatchId", "terminalHandle", "createdAt", "status"],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "dispatchId": { "type": "string", "minLength": 1 },
        "terminalHandle": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "enum": ["dispatched", "active", "completed", "failed", "blocked", "cancelled"] }
      }
    },
    "worktree": {
      "type": "object",
      "required": ["id", "path", "branch", "recordedBase", "setupMode"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/path" },
        "branch": { "type": "string", "minLength": 1 },
        "recordedBase": { "$ref": "#/$defs/fullOid" },
        "setupMode": { "enum": ["skip", "inherit"] }
      }
    },
    "terminal": {
      "type": "object",
      "required": ["handle", "worktreeId", "title", "command", "identity"],
      "additionalProperties": false,
      "properties": {
        "handle": { "type": "string", "minLength": 1 },
        "worktreeId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "command": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "identity": { "type": "string", "minLength": 1 }
      }
    },
    "promptDelivery": {
      "type": "object",
      "required": [
        "taskId",
        "dispatchId",
        "terminalHandle",
        "path",
        "sha256",
        "bytes",
        "dispatchShowArtifact",
        "preSubmitReadArtifact",
        "pastedComposerVisible",
        "enterSubmissionCount",
        "enterSubmissionArtifact",
        "postSubmitReadArtifact",
        "observedActiveState",
        "acceptedAt",
        "waitStartedAfterAccepted",
        "accepted"
      ],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "dispatchId": { "type": "string", "minLength": 1 },
        "terminalHandle": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 },
        "dispatchShowArtifact": { "$ref": "#/$defs/evidence" },
        "preSubmitReadArtifact": { "$ref": "#/$defs/evidence" },
        "pastedComposerVisible": { "type": "boolean" },
        "enterSubmissionCount": { "type": "integer", "minimum": 0, "maximum": 1 },
        "enterSubmissionArtifact": { "anyOf": [{ "$ref": "#/$defs/evidence" }, { "type": "null" }] },
        "postSubmitReadArtifact": { "$ref": "#/$defs/evidence" },
        "observedActiveState": {
          "const": "active",
          "description": "The post-submit terminal read must prove the dispatched task is active, not merely accepted by injection."
        },
        "acceptedAt": { "type": "string", "format": "date-time" },
        "waitStartedAfterAccepted": {
          "const": true,
          "description": "No orchestration long wait may begin until active-state acceptance has been recorded."
        },
        "acknowledgmentArtifact": { "anyOf": [{ "$ref": "#/$defs/evidence" }, { "type": "null" }] },
        "accepted": {
          "const": true,
          "description": "Requires dispatch-show and terminal-read proof; send/inject acknowledgment alone is insufficient."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "pastedComposerVisible": { "const": true } },
            "required": ["pastedComposerVisible"]
          },
          "then": {
            "properties": {
              "enterSubmissionCount": { "const": 1 },
              "enterSubmissionArtifact": { "$ref": "#/$defs/evidence" }
            }
          }
        },
        {
          "if": {
            "properties": { "pastedComposerVisible": { "const": false } },
            "required": ["pastedComposerVisible"]
          },
          "then": {
            "properties": {
              "enterSubmissionCount": { "const": 0 },
              "enterSubmissionArtifact": { "type": "null" }
            }
          }
        }
      ]
    },
    "authenticationReceipt": {
      "type": "object",
      "required": ["path", "sha256", "bytes", "redacted"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 },
        "redacted": {
          "const": true,
          "description": "This receipt records mode and probe outcome, never credential values or raw environment content."
        }
      }
    },
    "authenticatedProbe": {
      "type": "object",
      "required": ["executedAt", "exactChildEnvironment", "authenticated", "artifact"],
      "additionalProperties": false,
      "properties": {
        "executedAt": { "type": "string", "format": "date-time" },
        "exactChildEnvironment": {
          "const": true,
          "description": "The probe uses the same reviewed environment and invocation shape as the child terminal."
        },
        "authenticated": { "const": true },
        "artifact": { "$ref": "#/$defs/authenticationReceipt" }
      }
    },
    "authentication": {
      "type": "object",
      "required": ["mode", "redactedReceipt", "authenticatedProbe"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["broker", "trusted-controller-vault"],
          "description": "Broker is preferred. The vault fallback shares only the trusted controller credential store."
        },
        "redactedReceipt": { "$ref": "#/$defs/authenticationReceipt" },
        "authenticatedProbe": { "$ref": "#/$defs/authenticatedProbe" }
      }
    },
    "approvalPolicy": {
      "type": "object",
      "required": ["autoResolve", "eligibleChoices", "mandatoryEscalations", "exactPreauthorizationRequired", "receipt"],
      "additionalProperties": false,
      "properties": {
        "autoResolve": { "enum": ["recommended", "approve"] },
        "eligibleChoices": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["recommended", "approve"] }
        },
        "mandatoryEscalations": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true,
          "items": {
            "enum": [
              "destructive",
              "irreversible",
              "credential",
              "secret",
              "external-production",
              "parent-mutation",
              "merge",
              "push",
              "deploy",
              "material-scope-change"
            ]
          }
        },
        "exactPreauthorizationRequired": { "const": true },
        "receipt": { "$ref": "#/$defs/evidence" }
      }
    },
    "decisionReceipt": {
      "type": "object",
      "required": ["taskId", "dispatchId", "choice", "source", "reversible", "inScope", "planPreserving", "automatic", "artifact"],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "dispatchId": { "type": "string", "minLength": 1 },
        "choice": { "enum": ["recommended", "approve"] },
        "source": { "const": "serialized-approval-policy" },
        "reversible": { "const": true },
        "inScope": { "const": true },
        "planPreserving": { "const": true },
        "automatic": { "const": true },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "handoff": {
      "type": "object",
      "required": ["fromTaskId", "toTaskId", "artifacts", "validatedAt"],
      "additionalProperties": false,
      "properties": {
        "fromTaskId": { "type": "string", "minLength": 1 },
        "toTaskId": { "type": "string", "minLength": 1 },
        "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
        "validatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "validation": {
      "type": "object",
      "required": ["name", "argv", "cwd", "startedAt", "endedAt", "exitCode", "stdout", "stderr"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "argv": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "cwd": { "$ref": "#/$defs/path" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "exitCode": { "type": "integer", "minimum": 0 },
        "stdout": { "$ref": "#/$defs/evidence" },
        "stderr": { "$ref": "#/$defs/evidence" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["path", "sha256", "bytes"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "cleanupReceipt": {
      "type": "object",
      "required": ["worktreeId", "head", "branchRef", "status", "decision", "artifact"],
      "additionalProperties": false,
      "properties": {
        "worktreeId": { "type": "string", "minLength": 1 },
        "head": { "$ref": "#/$defs/fullOid" },
        "branchRef": { "type": "string", "minLength": 1 },
        "status": { "type": "array", "items": { "type": "string" } },
        "decision": { "enum": ["removed", "preserved", "cleanup-blocked"] },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "finalReport": {
      "type": "object",
      "required": ["path", "sha256", "selectedHead", "parentInvariantMatch"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "selectedHead": { "$ref": "#/$defs/fullOid" },
        "parentInvariantMatch": { "type": "boolean" }
      }
    }
  }
}
