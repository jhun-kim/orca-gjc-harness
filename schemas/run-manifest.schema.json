{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jhun-kim.github.io/orca-gjc-harness/schemas/run-manifest.schema.json",
  "title": "Orca GJC Harness Run Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "createdAt",
    "coordinatorHandle",
    "parentInvariantBefore",
    "parentInvariantAfter",
    "trust",
    "runtimePolicy",
    "source",
    "mode",
    "livenessPolicy",
    "approvalPolicy",
    "tasks",
    "validations",
    "evidence",
    "final",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.1" },
    "runId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "coordinatorHandle": { "type": "string", "minLength": 1 },
    "parentInvariantBefore": { "$ref": "#/$defs/parentInvariant" },
    "parentInvariantAfter": {
      "anyOf": [
        { "$ref": "#/$defs/parentInvariant" },
        { "type": "null" }
      ]
    },
    "trust": { "$ref": "#/$defs/trustDecision" },
    "runtimePolicy": { "$ref": "#/$defs/runtimePolicy" },
    "source": { "$ref": "#/$defs/sourceFact" },
    "mode": { "$ref": "#/$defs/mode" },
    "livenessPolicy": { "$ref": "#/$defs/livenessPolicy" },
    "approvalPolicy": { "$ref": "#/$defs/approvalPolicy" },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/taskLifecycle" },
      "uniqueItems": true
    },
    "validations": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation" },
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" },
      "uniqueItems": true
    },
    "final": {
      "anyOf": [
        { "$ref": "#/$defs/finalReport" },
        { "type": "null" }
      ]
    },
    "status": {
      "enum": [
        "planning",
        "running",
        "blocked",
        "failed",
        "validated",
        "cleanup-blocked",
        "complete"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "runtimePolicy": {
            "type": "object",
            "properties": {
              "authentication": {
                "type": "object",
                "properties": { "status": { "const": "blocked" } },
                "required": ["status"]
              }
            },
            "required": ["authentication"]
          }
        },
        "required": ["runtimePolicy"]
      },
      "then": {
        "type": "object",
        "properties": {
          "tasks": { "type": "array", "maxItems": 0 },
          "status": { "const": "blocked" }
        }
      }
    }
  ],
  "$defs": {
    "fullOid": { "type": "string", "pattern": "^[0-9a-f]{40,128}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "object",
      "required": ["path", "sha256", "bytes"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "redactedEvidence": {
      "type": "object",
      "required": ["path", "sha256", "bytes", "redacted"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 },
        "redacted": { "const": true }
      }
    },
    "parentInvariant": {
      "type": "object",
      "required": ["path", "branch", "head", "status"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "branch": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "head": { "$ref": "#/$defs/fullOid" },
        "status": { "type": "array", "items": { "type": "string" } }
      }
    },
    "trustDecision": {
      "type": "object",
      "required": ["classification", "rationale", "evidence"],
      "additionalProperties": false,
      "properties": {
        "classification": { "enum": ["trusted", "untrusted", "unknown"] },
        "rationale": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" },
          "uniqueItems": true
        }
      }
    },
    "route": {
      "type": "object",
      "required": ["provider", "model", "thinking", "contextLimit"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "model": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "thinking": { "enum": ["ultra", "high", "medium", "low"] },
        "contextLimit": { "type": "integer", "minimum": 1 }
      }
    },
    "clampingAdjustment": {
      "type": "object",
      "required": ["field", "requestedValue", "resolvedValue", "reason", "artifact"],
      "additionalProperties": false,
      "properties": {
        "field": { "enum": ["thinking", "contextLimit"] },
        "requestedValue": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "resolvedValue": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "reason": { "type": "string", "minLength": 1 },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "clamping": {
      "oneOf": [
        {
          "type": "object",
          "required": ["applied", "adjustments"],
          "additionalProperties": false,
          "properties": {
            "applied": { "const": false },
            "adjustments": { "type": "array", "maxItems": 0 }
          }
        },
        {
          "type": "object",
          "required": ["applied", "adjustments"],
          "additionalProperties": false,
          "properties": {
            "applied": { "const": true },
            "adjustments": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/clampingAdjustment" },
              "uniqueItems": true
            }
          }
        }
      ]
    },
    "fallbackAttempt": {
      "type": "object",
      "required": ["ordinal", "route", "outcome", "rejectionReason", "artifact"],
      "additionalProperties": false,
      "properties": {
        "ordinal": { "type": "integer", "minimum": 1 },
        "route": { "$ref": "#/$defs/route" },
        "outcome": { "enum": ["rejected", "selected"] },
        "rejectionReason": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "artifact": { "$ref": "#/$defs/evidence" }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": { "outcome": { "const": "rejected" } },
            "required": ["outcome"]
          },
          "then": {
            "type": "object",
            "properties": { "rejectionReason": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": { "outcome": { "const": "selected" } },
            "required": ["outcome"]
          },
          "then": {
            "type": "object",
            "properties": { "rejectionReason": { "type": "null" } }
          }
        }
      ]
    },
    "routeSelection": {
      "type": "object",
      "required": ["source", "fallbackOrdinal", "resolvedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "source": { "enum": ["requested", "fallback"] },
        "fallbackOrdinal": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "resolvedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": { "source": { "const": "requested" } },
            "required": ["source"]
          },
          "then": { "type": "object", "properties": { "fallbackOrdinal": { "type": "null" } } }
        },
        {
          "if": {
            "type": "object",
            "properties": { "source": { "const": "fallback" } },
            "required": ["source"]
          },
          "then": { "type": "object", "properties": { "fallbackOrdinal": { "type": "integer", "minimum": 1 } } }
        }
      ]
    },
    "routing": {
      "type": "object",
      "required": ["requested", "resolved", "clamping", "fallbackAttempts", "selection"],
      "additionalProperties": false,
      "properties": {
        "requested": { "$ref": "#/$defs/route" },
        "resolved": { "$ref": "#/$defs/route" },
        "clamping": { "$ref": "#/$defs/clamping" },
        "fallbackAttempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/fallbackAttempt" },
          "uniqueItems": true
        },
        "selection": { "$ref": "#/$defs/routeSelection" }
      }
    },
    "authenticationProbe": {
      "type": "object",
      "required": [
        "executedAt",
        "exactChildEnvironment",
        "exactLaunchEnvelope",
        "authenticated",
        "environmentSha256",
        "argvSha256",
        "sanitizedArgv",
        "artifact"
      ],
      "additionalProperties": false,
      "properties": {
        "executedAt": { "type": "string", "format": "date-time" },
        "exactChildEnvironment": { "const": true },
        "exactLaunchEnvelope": { "const": true },
        "authenticated": { "type": "boolean" },
        "environmentSha256": { "$ref": "#/$defs/sha256" },
        "argvSha256": { "$ref": "#/$defs/sha256" },
        "sanitizedArgv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "^--(credential|api-key|mpreset|default)$" }
          }
        },
        "artifact": { "$ref": "#/$defs/redactedEvidence" }
      }
    },
    "authentication": {
      "type": "object",
      "required": ["mode", "status", "blockedReason", "redactedReceipt", "probe"],
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["broker", "trusted-controller-vault"] },
        "status": { "enum": ["authenticated", "blocked"] },
        "blockedReason": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "redactedReceipt": { "$ref": "#/$defs/redactedEvidence" },
        "probe": { "$ref": "#/$defs/authenticationProbe" }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": { "status": { "const": "authenticated" } },
            "required": ["status"]
          },
          "then": {
            "type": "object",
            "properties": {
              "blockedReason": { "type": "null" },
              "probe": {
                "type": "object",
                "properties": { "authenticated": { "const": true } },
                "required": ["authenticated"]
              }
            }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": { "status": { "const": "blocked" } },
            "required": ["status"]
          },
          "then": {
            "type": "object",
            "properties": {
              "blockedReason": { "type": "string", "minLength": 1 },
              "probe": {
                "type": "object",
                "properties": { "authenticated": { "const": false } },
                "required": ["authenticated"]
              }
            }
          }
        }
      ]
    },
    "runtimePolicy": {
      "type": "object",
      "required": [
        "setupMode",
        "gjcBinary",
        "routing",
        "tools",
        "goalEnabled",
        "isolation",
        "authentication"
      ],
      "additionalProperties": false,
      "properties": {
        "setupMode": { "enum": ["skip", "inherit"] },
        "gjcBinary": {
          "type": "object",
          "required": ["path", "sha256", "versionArtifact", "modelCatalogArtifact", "provenance"],
          "additionalProperties": false,
          "properties": {
            "path": { "$ref": "#/$defs/path" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "versionArtifact": { "$ref": "#/$defs/evidence" },
            "modelCatalogArtifact": { "$ref": "#/$defs/evidence" },
            "provenance": { "type": "string", "minLength": 1 }
          }
        },
        "routing": { "$ref": "#/$defs/routing" },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["read", "search", "find", "edit", "write", "bash"] },
          "uniqueItems": true
        },
        "goalEnabled": { "const": false },
        "isolation": {
          "type": "object",
          "required": [
            "configDirectory",
            "sessionDirectory",
            "sessionPersistence",
            "extensionsEnabled",
            "skillsEnabled",
            "rulesEnabled",
            "ptyEnabled",
            "environmentReceipt",
            "configurationReceipt",
            "sessionReceipt"
          ],
          "additionalProperties": false,
          "properties": {
            "configDirectory": { "$ref": "#/$defs/path" },
            "sessionDirectory": { "$ref": "#/$defs/path" },
            "sessionPersistence": { "const": false },
            "extensionsEnabled": { "const": false },
            "skillsEnabled": { "const": false },
            "rulesEnabled": { "const": false },
            "ptyEnabled": { "const": false },
            "environmentReceipt": { "$ref": "#/$defs/redactedEvidence" },
            "configurationReceipt": { "$ref": "#/$defs/redactedEvidence" },
            "sessionReceipt": { "$ref": "#/$defs/redactedEvidence" }
          }
        },
        "authentication": { "$ref": "#/$defs/authentication" }
      }
    },
    "sourceFact": {
      "type": "object",
      "required": ["contractPath", "contractSha256", "sourceHead"],
      "additionalProperties": false,
      "properties": {
        "contractPath": { "$ref": "#/$defs/path" },
        "contractSha256": { "$ref": "#/$defs/sha256" },
        "sourceHead": { "$ref": "#/$defs/fullOid" }
      }
    },
    "mode": {
      "type": "object",
      "required": ["selected", "reason", "conditionalIntegration"],
      "additionalProperties": false,
      "properties": {
        "selected": { "enum": ["single", "race", "parallel-build", "pipeline"] },
        "reason": { "type": "string", "minLength": 1 },
        "conditionalIntegration": { "type": "boolean" }
      }
    },
    "livenessPolicy": {
      "type": "object",
      "required": [
        "promptAcceptanceTimeoutSeconds",
        "activePollTimeoutSeconds",
        "activeLivenessWindowSeconds",
        "requiredActiveAbandonment",
        "optionalGraceDefaultSeconds",
        "optionalGraceMaximumSeconds",
        "optionalGraceStartsAfter"
      ],
      "additionalProperties": false,
      "properties": {
        "promptAcceptanceTimeoutSeconds": { "const": 60 },
        "activePollTimeoutSeconds": { "const": 60 },
        "activeLivenessWindowSeconds": { "const": 120 },
        "requiredActiveAbandonment": { "const": "forbidden-while-active" },
        "optionalGraceDefaultSeconds": { "const": 60 },
        "optionalGraceMaximumSeconds": { "const": 120 },
        "optionalGraceStartsAfter": { "const": "required-deliverables-verified" }
      }
    },
    "approvalPolicy": {
      "type": "object",
      "required": ["autoResolve", "eligibleChoices", "mandatoryEscalations", "exactPreauthorizationRequired", "receipt"],
      "additionalProperties": false,
      "properties": {
        "autoResolve": { "enum": ["recommended", "approve"] },
        "eligibleChoices": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["recommended", "approve"] }
        },
        "mandatoryEscalations": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true,
          "items": {
            "enum": [
              "destructive",
              "irreversible",
              "credential",
              "secret",
              "external-production",
              "parent-mutation",
              "merge",
              "push",
              "deploy",
              "material-scope-change"
            ]
          }
        },
        "exactPreauthorizationRequired": { "const": true },
        "receipt": { "$ref": "#/$defs/evidence" }
      }
    },
    "worktree": {
      "type": "object",
      "required": ["id", "path", "branch", "recordedBase", "setupMode"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/path" },
        "branch": { "type": "string", "minLength": 1 },
        "recordedBase": { "$ref": "#/$defs/fullOid" },
        "setupMode": { "enum": ["skip", "inherit"] }
      }
    },
    "promptSpec": {
      "type": "object",
      "required": ["path", "sha256", "bytes"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "validationCommand": {
      "type": "object",
      "required": ["argv", "cwd"],
      "additionalProperties": false,
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cwd": { "$ref": "#/$defs/path" }
      }
    },
    "terminal": {
      "type": "object",
      "required": ["handle", "stableIdentity", "title", "agentType", "launchedAt", "launchEnvelopeArtifact"],
      "additionalProperties": false,
      "properties": {
        "handle": { "type": "string", "minLength": 1 },
        "stableIdentity": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "agentType": { "const": "gjc" },
        "launchedAt": { "type": "string", "format": "date-time" },
        "launchEnvelopeArtifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "dispatchReceipt": {
      "type": "object",
      "required": ["dispatchId", "createdAt", "status", "terminal"],
      "additionalProperties": false,
      "properties": {
        "dispatchId": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "enum": ["dispatched", "active", "completed", "failed", "blocked", "cancelled"] },
        "terminal": { "$ref": "#/$defs/terminal" }
      }
    },
    "promptIdentity": {
      "type": "object",
      "required": ["taskId", "dispatchId", "terminalHandle", "stableTerminalIdentity"],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "dispatchId": { "type": "string", "minLength": 1 },
        "terminalHandle": { "type": "string", "minLength": 1 },
        "stableTerminalIdentity": { "type": "string", "minLength": 1 }
      }
    },
    "taskDispatchIdentity": {
      "type": "object",
      "required": ["taskId", "dispatchId"],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "dispatchId": { "type": "string", "minLength": 1 }
      }
    },
    "preComposerPhase": {
      "type": "object",
      "required": ["sequence", "phase", "terminalState", "cursor", "capturedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "const": 1 },
        "phase": { "const": "pre-submit-read" },
        "terminalState": { "const": "composer-visible" },
        "cursor": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "preActivePhase": {
      "type": "object",
      "required": ["sequence", "phase", "terminalState", "cursor", "capturedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "const": 1 },
        "phase": { "const": "pre-submit-read" },
        "terminalState": { "const": "active" },
        "cursor": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "enterPhase": {
      "type": "object",
      "required": ["sequence", "phase", "submissionCount", "submittedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "const": 2 },
        "phase": { "const": "enter-submit" },
        "submissionCount": { "const": 1 },
        "submittedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "postActivePhaseAfterEnter": {
      "type": "object",
      "required": ["sequence", "phase", "terminalState", "cursor", "capturedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "const": 3 },
        "phase": { "const": "post-submit-read" },
        "terminalState": { "const": "active" },
        "cursor": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "postActivePhaseWithoutEnter": {
      "type": "object",
      "required": ["sequence", "phase", "terminalState", "cursor", "capturedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "const": 2 },
        "phase": { "const": "post-submit-read" },
        "terminalState": { "const": "active" },
        "cursor": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "acceptedPromptPhases": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            { "$ref": "#/$defs/preComposerPhase" },
            { "$ref": "#/$defs/enterPhase" },
            { "$ref": "#/$defs/postActivePhaseAfterEnter" }
          ],
          "items": false
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            { "$ref": "#/$defs/preActivePhase" },
            { "$ref": "#/$defs/postActivePhaseWithoutEnter" }
          ],
          "items": false
        }
      ]
    },
    "blockedPromptPhase": {
      "type": "object",
      "required": ["sequence", "phase", "terminalState", "cursor", "capturedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "type": "integer", "minimum": 1, "maximum": 3 },
        "phase": { "enum": ["pre-submit-read", "post-submit-read"] },
        "terminalState": { "enum": ["composer-visible", "idle", "unknown"] },
        "cursor": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "acceptedPromptDelivery": {
      "type": "object",
      "required": [
        "identity",
        "promptSha256",
        "dispatchShowArtifact",
        "acceptanceTimeoutSeconds",
        "startedAt",
        "deadlineAt",
        "resendCount",
        "attemptNumber",
        "phases",
        "outcome",
        "acceptedAt",
        "longWaitAllowed"
      ],
      "additionalProperties": false,
      "properties": {
        "identity": { "$ref": "#/$defs/promptIdentity" },
        "promptSha256": { "$ref": "#/$defs/sha256" },
        "dispatchShowArtifact": { "$ref": "#/$defs/evidence" },
        "acceptanceTimeoutSeconds": { "const": 60 },
        "startedAt": { "type": "string", "format": "date-time" },
        "deadlineAt": { "type": "string", "format": "date-time" },
        "resendCount": { "const": 0 },
        "attemptNumber": { "const": 1 },
        "phases": { "$ref": "#/$defs/acceptedPromptPhases" },
        "outcome": { "const": "accepted" },
        "acceptedAt": { "type": "string", "format": "date-time" },
        "longWaitAllowed": { "const": true }
      }
    },
    "blockedPromptDelivery": {
      "type": "object",
      "required": [
        "identity",
        "promptSha256",
        "dispatchShowArtifact",
        "acceptanceTimeoutSeconds",
        "startedAt",
        "deadlineAt",
        "resendCount",
        "attemptNumber",
        "phases",
        "outcome",
        "acceptedAt",
        "blockedAt",
        "blockedReason",
        "longWaitAllowed"
      ],
      "additionalProperties": false,
      "properties": {
        "identity": { "$ref": "#/$defs/promptIdentity" },
        "promptSha256": { "$ref": "#/$defs/sha256" },
        "dispatchShowArtifact": { "$ref": "#/$defs/evidence" },
        "acceptanceTimeoutSeconds": { "const": 60 },
        "startedAt": { "type": "string", "format": "date-time" },
        "deadlineAt": { "type": "string", "format": "date-time" },
        "resendCount": { "const": 0 },
        "attemptNumber": { "const": 1 },
        "phases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/blockedPromptPhase" },
          "uniqueItems": true
        },
        "outcome": { "const": "blocked" },
        "acceptedAt": { "type": "null" },
        "blockedAt": { "type": "string", "format": "date-time" },
        "blockedReason": {
          "enum": [
            "active-evidence-timeout",
            "composer-remained-visible",
            "identity-ambiguity",
            "stale-terminal",
            "dispatch-mismatch"
          ]
        },
        "longWaitAllowed": { "const": false }
      }
    },
    "promptDelivery": {
      "oneOf": [
        { "$ref": "#/$defs/acceptedPromptDelivery" },
        { "$ref": "#/$defs/blockedPromptDelivery" },
        { "type": "null" }
      ]
    },
    "monitorPoll": {
      "type": "object",
      "required": ["sequence", "startedAt", "endedAt", "result", "activeEvidenceAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "result": { "enum": ["active", "completed", "failed", "blocked"] },
        "activeEvidenceAt": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "artifact": { "$ref": "#/$defs/evidence" }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": { "result": { "const": "active" } },
            "required": ["result"]
          },
          "then": { "type": "object", "properties": { "activeEvidenceAt": { "type": "string", "format": "date-time" } } }
        }
      ]
    },
    "optionalGrace": {
      "type": "object",
      "required": [
        "policySource",
        "configuredSeconds",
        "requiredDeliverablesVerifiedAt",
        "startedAt",
        "endedAt",
        "outcome",
        "artifact"
      ],
      "additionalProperties": false,
      "properties": {
        "policySource": { "enum": ["default-60", "explicit-at-most-120"] },
        "configuredSeconds": { "type": "integer", "minimum": 0, "maximum": 120 },
        "requiredDeliverablesVerifiedAt": { "type": "string", "format": "date-time" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "outcome": { "enum": ["completed", "grace-expired", "failed", "blocked"] },
        "artifact": { "$ref": "#/$defs/evidence" }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": { "policySource": { "const": "default-60" } },
            "required": ["policySource"]
          },
          "then": { "type": "object", "properties": { "configuredSeconds": { "const": 60 } } }
        }
      ]
    },
    "monitoring": {
      "type": "object",
      "required": [
        "startedAt",
        "pollTimeoutSeconds",
        "livenessWindowSeconds",
        "polls",
        "lastActiveAt",
        "outcome",
        "abandoned",
        "optionalGrace"
      ],
      "additionalProperties": false,
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "pollTimeoutSeconds": { "const": 60 },
        "livenessWindowSeconds": { "const": 120 },
        "polls": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/monitorPoll" },
          "uniqueItems": true
        },
        "lastActiveAt": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "outcome": { "enum": ["active", "completed", "failed", "blocked", "cancelled"] },
        "abandoned": { "const": false },
        "optionalGrace": {
          "anyOf": [
            { "$ref": "#/$defs/optionalGrace" },
            { "type": "null" }
          ]
        }
      }
    },
    "automaticDecision": {
      "type": "object",
      "required": ["identity", "kind", "choice", "source", "reversible", "inScope", "planPreserving", "automatic", "recordedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "identity": { "$ref": "#/$defs/taskDispatchIdentity" },
        "kind": { "const": "automatic" },
        "choice": { "enum": ["recommended", "approve"] },
        "source": { "const": "serialized-approval-policy" },
        "reversible": { "const": true },
        "inScope": { "const": true },
        "planPreserving": { "const": true },
        "automatic": { "const": true },
        "recordedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "escalatedDecision": {
      "type": "object",
      "required": ["identity", "kind", "category", "automatic", "recordedAt", "artifact"],
      "additionalProperties": false,
      "properties": {
        "identity": { "$ref": "#/$defs/taskDispatchIdentity" },
        "kind": { "const": "escalated" },
        "category": {
          "enum": [
            "destructive",
            "irreversible",
            "credential",
            "secret",
            "external-production",
            "parent-mutation",
            "merge",
            "push",
            "deploy",
            "material-scope-change"
          ]
        },
        "automatic": { "const": false },
        "recordedAt": { "type": "string", "format": "date-time" },
        "artifact": { "$ref": "#/$defs/evidence" }
      }
    },
    "decision": {
      "oneOf": [
        { "$ref": "#/$defs/automaticDecision" },
        { "$ref": "#/$defs/escalatedDecision" },
        { "type": "null" }
      ]
    },
    "completion": {
      "type": "object",
      "required": ["identity", "status", "receivedAt", "receipt"],
      "additionalProperties": false,
      "properties": {
        "identity": { "$ref": "#/$defs/taskDispatchIdentity" },
        "status": { "enum": ["success", "failure", "blocked"] },
        "receivedAt": { "type": "string", "format": "date-time" },
        "receipt": { "$ref": "#/$defs/evidence" }
      }
    },
    "cleanupReceipt": {
      "type": "object",
      "required": ["worktreeId", "head", "branchRef", "checkoutState", "status", "decision", "artifact"],
      "additionalProperties": false,
      "properties": {
        "worktreeId": { "type": "string", "minLength": 1 },
        "head": { "$ref": "#/$defs/fullOid" },
        "branchRef": { "type": "string", "minLength": 1 },
        "checkoutState": { "enum": ["clean", "zero-delta", "dirty", "unknown", "deleted-worktree"] },
        "status": { "type": "array", "items": { "type": "string" } },
        "decision": { "enum": ["removed", "preserved", "cleanup-blocked"] },
        "artifact": { "$ref": "#/$defs/evidence" }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": { "checkoutState": { "enum": ["dirty", "unknown"] } },
            "required": ["checkoutState"]
          },
          "then": { "type": "object", "properties": { "decision": { "enum": ["preserved", "cleanup-blocked"] } } }
        },
        {
          "if": {
            "type": "object",
            "properties": { "checkoutState": { "const": "deleted-worktree" } },
            "required": ["checkoutState"]
          },
          "then": { "type": "object", "properties": { "decision": { "const": "cleanup-blocked" } } }
        }
      ]
    },
    "lifecycle": {
      "type": "object",
      "required": ["dispatch", "promptDelivery", "monitoring", "decision", "completion", "cleanup"],
      "additionalProperties": false,
      "properties": {
        "dispatch": {
          "anyOf": [
            { "$ref": "#/$defs/dispatchReceipt" },
            { "type": "null" }
          ]
        },
        "promptDelivery": { "$ref": "#/$defs/promptDelivery" },
        "monitoring": {
          "anyOf": [
            { "$ref": "#/$defs/monitoring" },
            { "type": "null" }
          ]
        },
        "decision": { "$ref": "#/$defs/decision" },
        "completion": {
          "anyOf": [
            { "$ref": "#/$defs/completion" },
            { "type": "null" }
          ]
        },
        "cleanup": {
          "anyOf": [
            { "$ref": "#/$defs/cleanupReceipt" },
            { "type": "null" }
          ]
        }
      }
    },
    "taskLifecycle": {
      "type": "object",
      "required": [
        "taskId",
        "phase",
        "dependsOn",
        "required",
        "worktree",
        "ownedPaths",
        "promptSpec",
        "acceptance",
        "validationCommands",
        "handoffInputs",
        "handoffOutputs",
        "lifecycle",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "phase": { "type": "string", "minLength": 1 },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "required": { "type": "boolean" },
        "worktree": { "$ref": "#/$defs/worktree" },
        "ownedPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/path" },
          "uniqueItems": true
        },
        "promptSpec": { "$ref": "#/$defs/promptSpec" },
        "acceptance": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "validationCommands": {
          "type": "array",
          "items": { "$ref": "#/$defs/validationCommand" },
          "uniqueItems": true
        },
        "handoffInputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" },
          "uniqueItems": true
        },
        "handoffOutputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" },
          "uniqueItems": true
        },
        "lifecycle": { "$ref": "#/$defs/lifecycle" },
        "status": {
          "enum": ["pending", "ready", "active", "completed", "failed", "blocked", "cancelled", "cleanup-blocked"]
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["name", "argv", "cwd", "startedAt", "endedAt", "exitCode", "stdout", "stderr"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cwd": { "$ref": "#/$defs/path" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "exitCode": { "type": "integer", "minimum": 0 },
        "stdout": { "$ref": "#/$defs/evidence" },
        "stderr": { "$ref": "#/$defs/evidence" }
      }
    },
    "finalReport": {
      "type": "object",
      "required": ["path", "sha256", "selectedHead", "parentInvariantMatch"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "selectedHead": { "$ref": "#/$defs/fullOid" },
        "parentInvariantMatch": { "type": "boolean" }
      }
    }
  }
}
